---
import { getEntry } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";

const locale = "sk" as const;
const entry = await getEntry("pages", "sk/contact");
const { Content } = await entry!.render();
const { title, description } = entry!.data;
---

<BaseLayout title={`${title} — LIFO 2027`} description={description} locale={locale}>
  <Header locale={locale} />

  <main id="main">
    <section class="bg-lifo-navy py-16 text-lifo-paper sm:py-24">
      <div class="container-lifo">
        <p class="mb-3 font-display text-sm font-semibold uppercase tracking-[0.2em] text-lifo-paper/60">
          LIFO 2027
        </p>
        <h1 class="mb-6 font-display text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl">
          {title}
        </h1>
        {description && <p class="max-w-2xl text-lg text-lifo-paper/85 sm:text-xl">{description}</p>}
      </div>
    </section>

    <section class="py-16 sm:py-20">
      <div class="container-lifo">
        <div class="grid gap-10 md:grid-cols-[1fr_1.2fr]">
          <article class="prose-lifo">
            <Content />
          </article>

          <aside>
            <form
              name="contact"
              method="POST"
              data-netlify="true"
              netlify-honeypot="bot-field"
              class="rounded-2xl border border-lifo-ink/10 bg-lifo-ink/[0.02] p-8"
            >
              <input type="hidden" name="form-name" value="contact" />
              <p class="hidden">
                <label
                  >Don't fill this: <input name="bot-field" />
                </label>
              </p>

              <h2 class="mb-6 text-2xl font-bold">Napíšte nám</h2>

              <fieldset class="mb-5">
                <legend class="mb-2 block text-sm font-semibold">Som*</legend>
                <div class="space-y-2 text-sm">
                  <label class="flex items-center gap-2">
                    <input type="radio" name="segment" value="sponzor" required /> Záujemca o partnerstvo / sponzoring
                  </label>
                  <label class="flex items-center gap-2">
                    <input type="radio" name="segment" value="spiker" /> Záujemca o rečnenie
                  </label>
                  <label class="flex items-center gap-2">
                    <input type="radio" name="segment" value="samosprava" /> Samospráva
                  </label>
                  <label class="flex items-center gap-2">
                    <input type="radio" name="segment" value="media" /> Médiá
                  </label>
                  <label class="flex items-center gap-2">
                    <input type="radio" name="segment" value="ine" /> Iné
                  </label>
                </div>
              </fieldset>

              <label class="mb-4 block">
                <span class="mb-1 block text-sm font-semibold">Meno*</span>
                <input
                  name="name"
                  type="text"
                  required
                  minlength="2"
                  class="w-full rounded-lg border border-lifo-ink/20 bg-lifo-paper px-4 py-2 focus:border-lifo-magenta focus:outline-none"
                />
              </label>

              <label class="mb-4 block">
                <span class="mb-1 block text-sm font-semibold">E-mail*</span>
                <input
                  name="email"
                  type="email"
                  required
                  class="w-full rounded-lg border border-lifo-ink/20 bg-lifo-paper px-4 py-2 focus:border-lifo-magenta focus:outline-none"
                />
              </label>

              <label class="mb-4 block">
                <span class="mb-1 block text-sm font-semibold">Organizácia</span>
                <input
                  name="organization"
                  type="text"
                  class="w-full rounded-lg border border-lifo-ink/20 bg-lifo-paper px-4 py-2 focus:border-lifo-magenta focus:outline-none"
                />
              </label>

              <label class="mb-4 block">
                <span class="mb-1 block text-sm font-semibold">Správa*</span>
                <textarea
                  name="message"
                  required
                  minlength="10"
                  maxlength="2000"
                  rows="5"
                  class="w-full rounded-lg border border-lifo-ink/20 bg-lifo-paper px-4 py-2 focus:border-lifo-magenta focus:outline-none"
                ></textarea>
              </label>

              <label class="mb-6 flex items-start gap-2 text-sm">
                <input type="checkbox" name="gdpr" required class="mt-1" />
                <span>
                  Súhlasím so spracovaním osobných údajov pre účely vybavenia môjho dopytu podľa
                  <a href="/zasady-ochrany-osobnych-udajov" class="text-lifo-magenta underline hover:no-underline">Zásad ochrany osobných údajov</a>. *
                </span>
              </label>

              <button type="submit" class="btn-primary w-full">Odoslať dopyt</button>
            </form>
          </aside>
        </div>
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</BaseLayout>
