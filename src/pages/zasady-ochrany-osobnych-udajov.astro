---
import { getEntry } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";

const locale = "sk" as const;
const entry = await getEntry("pages", "sk/privacy");
const { Content } = await entry!.render();
const { title, description } = entry!.data;
---

<BaseLayout title={`${title} — LIFO 2027`} description={description} locale={locale}>
  <Header locale={locale} />

  <main id="main">
    <section class="bg-lifo-navy py-12 text-lifo-paper sm:py-16">
      <div class="container-lifo">
        <p class="mb-3 font-display text-sm font-semibold uppercase tracking-[0.2em] text-lifo-paper/60">
          LIFO 2027
        </p>
        <h1 class="font-display text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl">
          {title}
        </h1>
      </div>
    </section>

    <section class="py-16 sm:py-20">
      <div class="container-lifo">
        <article class="prose-lifo max-w-3xl">
          <Content />
        </article>
      </div>
    </section>
  </main>

  <Footer locale={locale} />
</BaseLayout>
